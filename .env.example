# ============================================================
# NeoLink — .env.example
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Node ─────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=4000
LOG_LEVEL=debug               # error | warn | info | http | debug

# ── App URL ──────────────────────────────
# Controls all OAuth callback URLs: ${APP_URL}/api/v1/platforms/{platform}/callback
# Set this to https://www.omnipublish.io in production.
APP_URL=http://localhost:4000

# Public site URLs for OAuth app dashboards
# Terms of Service: https://www.omnipublish.io/terms
# Privacy Policy: https://www.omnipublish.io/privacy
# Web/Desktop URL: https://www.omnipublish.io

# ── CORS ─────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Supabase ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=media

# ── Database (direct Postgres — used by db/migrate.js) ────
# Find in Supabase dashboard: Settings > Database > Connection string
# Use the "URI" format under "Direct connection"
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── JWT ──────────────────────────────────
# Generate each with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_32_byte_hex_string
JWT_REFRESH_SECRET=change_me_32_byte_hex_string
JWT_EMAIL_CONFIRM_SECRET=change_me_32_byte_hex_string
JWT_OAUTH_EXCHANGE_SECRET=change_me_32_byte_hex_string

# ── Encryption ───────────────────────────
# AES-256 key — must be exactly 32 bytes (64 hex chars)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change_me_64_char_hex_32_bytes

# ── AI Providers ─────────────────────────
# Default: Anthropic. Set AI_PROVIDER=openai-compatible to use Ollama/vLLM/OpenAI-compatible servers.
AI_PROVIDER=anthropic
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=ollama
AI_MODEL=qwen2.5:7b-instruct

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-...

# ── Platform OAuth credentials ───────────
# All OAuth callback URLs follow this pattern (registered in each platform's dev portal):
#   https://omnipublish.io/api/v1/platforms/{platform}/callback
#
# Platform-specific callback URLs:
#   YouTube / Google : https://omnipublish.io/api/v1/platforms/youtube/callback
#   X (Twitter)      : https://omnipublish.io/api/v1/platforms/x/callback
#   LinkedIn         : https://omnipublish.io/api/v1/platforms/linkedin/callback
#   Facebook         : https://omnipublish.io/api/v1/platforms/facebook/callback
#   Instagram        : https://omnipublish.io/api/v1/platforms/instagram/callback
#   TikTok           : https://omnipublish.io/api/v1/platforms/tiktok/callback
#   Reddit           : https://omnipublish.io/api/v1/platforms/reddit/callback
#   Pinterest        : https://omnipublish.io/api/v1/platforms/pinterest/callback
#   Twitch           : https://omnipublish.io/api/v1/platforms/twitch/callback

# Facebook / Meta
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# X (Twitter)
X_CLIENT_ID=
X_CLIENT_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Google OAuth — YouTube + Sign In with Google
# Create at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Register redirect URI: https://omnipublish.io/api/v1/platforms/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Instagram (Meta)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# TikTok
# Register redirect URI: https://omnipublish.io/api/v1/platforms/tiktok/callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=


# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Pinterest
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# Telegram (Bot Token — no OAuth, use BotFather)
TELEGRAM_BOT_TOKEN=

# Bluesky (App Password — no OAuth)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Rumble
RUMBLE_API_KEY=

# Snapchat
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
SNAPCHAT_APP_ID=
SNAPCHAT_PUBLISHER_ID=

# Twitch
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Threads (via Meta)
THREADS_APP_ID=
THREADS_APP_SECRET=

# ── Email (for password reset / notifications) ──
EMAIL_PROVIDER=sendgrid       # sendgrid | resend | ses
SENDGRID_API_KEY=
FROM_EMAIL=noreply@localhost
FROM_NAME=OmniPublish

# ── Redis (optional — for distributed rate limiting) ──
REDIS_URL=redis://localhost:6379

# ── Monitoring (optional) ────────────────
SENTRY_DSN=
