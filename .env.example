# ============================================================
# OmniPublish — .env.example
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Node ─────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=4000
LOG_LEVEL=debug               # error | warn | info | http | debug

# ── CORS ─────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://omnipublish.com

# ── Supabase ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=media

# ── Database (direct Postgres — used by db/migrate.js) ────
# Find in Supabase dashboard: Settings > Database > Connection string
# Use the "URI" format under "Direct connection"
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── JWT ──────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_64_char_hex_string_access
JWT_REFRESH_SECRET=change_me_64_char_hex_string_refresh
# Enforce that JWTs only work for active users after a bulk reset
REQUIRE_ACTIVE_USER=true

# ── Encryption ───────────────────────────
# AES-256 key — must be exactly 32 bytes (64 hex chars)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change_me_64_char_hex_32_bytes

# ── Anthropic AI ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Platform OAuth credentials ───────────
# Facebook / Meta
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# X (Twitter)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=https://omnipublish.com/api/v1/auth/callback/x

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=https://omnipublish.com/api/v1/auth/callback/linkedin

# Google OAuth (Sign Up / Sign In with Google)
# Create credentials at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URIs to register:
#   Development: http://localhost:4000/api/v1/auth/google/callback
#   Production:  ${APP_URL}/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Instagram (Meta)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Pinterest
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Telegram (Bot Token)
TELEGRAM_BOT_TOKEN=

# Bluesky (App Password)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Rumble
RUMBLE_API_KEY=

# Snapchat
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# Twitch
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Threads (via Meta)
THREADS_APP_ID=
THREADS_APP_SECRET=

# ── Email (for password reset / notifications) ──
EMAIL_PROVIDER=sendgrid       # sendgrid | resend | ses
SENDGRID_API_KEY=
FROM_EMAIL=noreply@omnipublish.com
FROM_NAME=OmniPublish

# ── Redis (optional — for distributed rate limiting) ──
REDIS_URL=redis://localhost:6379

# ── Monitoring (optional) ────────────────
SENTRY_DSN=
